# =============================================================================
# samba system — variáveis de ambiente
# cp .env.example .env && edite os valores
# =============================================================================

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=samba2025
POSTGRES_DB=samba_db

# Senhas dos usuários de app
SCHOOL_DB_PASSWORD=school2025secure
CODE_DB_PASSWORD=code2025
EDVANCE_DB_PASSWORD=edvance2025
PAPER_DB_PASSWORD=paper2025

# JWT (gere com: openssl rand -base64 32)
JWT_SECRET=troque-por-um-secret-seguro

# Hash SHA-256 da senha de deploy (gere com: echo -n 'sua_senha' | sha256sum)
DEPLOY_HASH_ENV=troque-pelo-hash-sha256-da-senha-de-deploy

# URLs públicas
URL_ACCESS=https://acesso.escolacabral.com.br
URL_EDVANCE=https://edvance.escolacabral.com.br
URL_CODE=https://code.escolacabral.com.br
URL_FLOURISH=https://flourish.escolacabral.com.br
URL_ADMIN=https://admin.escolacabral.com.br
URL_PAPER=https://paper.escolacabral.com.br

COOKIE_DOMAIN=.escolacabral.com.br
